# ============================================================
#  Bot Hosting Platform — Variáveis de Ambiente
#  Copiar para .env:   cp .env.example .env
#  Editar com:         nano .env   OU   vim .env
# ============================================================

# ── Base de Dados ────────────────────────────────────────────
POSTGRES_PASSWORD=MinhaPassword123!

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=MinhaRedis456!

# ── JWT — gerar 3 valores com: openssl rand -hex 32 ─────────
JWT_SECRET=troca_por_32bytes_hex
JWT_REFRESH_SECRET=troca_por_outro_32bytes_hex

# ── Segredo interno API <-> Runner ───────────────────────────
INTERNAL_SECRET=troca_por_mais_um_32bytes_hex

# ── URLs (sem domínio: usar localhost) ───────────────────────
# Com domínio:   FRONTEND_URL=https://seudominio.com
# Sem domínio:   deixar como está (localhost)
FRONTEND_URL=http://localhost:3001
FRONTEND_API_URL=http://localhost:3000

# ── Cookies de autenticação ──────────────────────────────────
# COOKIE_SECURE: true em produção (HTTPS). Não alterar em dev.
# COOKIE_SAMESITE: lax (padrão) ou none (cross-site, exige HTTPS)
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# ── Segredos de webhook dos gateways de pagamento ────────────
# Obrigatórios em produção — sem eles os webhooks são rejeitados.
# Gerar com: openssl rand -hex 32
MPESA_WEBHOOK_SECRET=troca_por_segredo_mpesa
EMOLA_WEBHOOK_SECRET=troca_por_segredo_emola
MKESH_WEBHOOK_SECRET=troca_por_segredo_mkesh

# ── Versão da aplicação ──────────────────────────────────────
APP_VERSION=1.0.0

# ── OpenAI (opcional — também configurável via painel) ───────
OPENAI_API_KEY=sk-...

# ── Docker Registry (só necessário para CI/CD remoto) ────────
REGISTRY=ghcr.io/pachir4428
TAG=latest
