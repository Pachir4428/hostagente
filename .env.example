# Database
# ─────────────────────────────────────────────────────────────
# Opção A — Postgres próprio (container local / VPS via docker-compose.prod.yml):
#   só precisas de POSTGRES_PASSWORD; DATABASE_URL e DIRECT_URL são
#   montados automaticamente pelos docker-compose.*.yml.
#
# Opção B — Supabase (docker-compose.supabase.yml, ou VPS apontando para fora):
#   cria um projeto em https://supabase.com/dashboard, vai a
#   Project Settings → Database → Connection string e preenche:
#     DATABASE_URL = "Connection pooling" (porta 6543, modo transaction) — usado em runtime
#     DIRECT_URL   = "Direct connection"  (porta 5432)                  — usado para migrações
#   Ambas terminam com ?sslmode=require
# ─────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password
# DATABASE_URL=postgresql://postgres.xxxxxxxx:SENHA@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
# DIRECT_URL=postgresql://postgres.xxxxxxxx:SENHA@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# Redis
REDIS_PASSWORD=changeme_redis_password

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Internal service secret
INTERNAL_SECRET=your_internal_secret_here

# URLs
FRONTEND_URL=http://localhost:3001
FRONTEND_API_URL=http://localhost:3000

# Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Payment webhooks (optional)
MPESA_WEBHOOK_SECRET=
EMOLA_WEBHOOK_SECRET=
MKESH_WEBHOOK_SECRET=

# AI (optional)
OPENAI_API_KEY=

# App
APP_VERSION=1.0.0
BOT_ENGINE_IMAGE=bot-engine:latest
