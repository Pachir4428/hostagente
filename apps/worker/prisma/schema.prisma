generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  STAFF
}

enum TenantStatus {
  trial
  active
  past_due
  suspended
  cancelled
}

enum SubStatus {
  trial
  active
  past_due
  cancelled
}

enum TxStatus {
  delivered
  refused
  duplicate
  pending
}

enum Operator {
  mpesa
  emola
  mkesh
}

model Plan {
  id              String   @id @default(uuid())
  name            String   @unique
  priceMonthly    Float    @default(0)
  maxTransactions Int      @default(1000)
  maxUsers        Int      @default(1)
  features        String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  tenants       Tenant[]
  subscriptions Subscription[]
}

model Tenant {
  id              String       @id @default(uuid())
  name            String
  contact         String?
  receivingNumber String?
  status          TenantStatus @default(trial)
  planId          String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  plan         Plan?         @relation(fields: [planId], references: [id])
  users        User[]
  products     Product[]
  transactions Transaction[]
  apiKeys      ApiKey[]
  subscription Subscription?
  invoices     Invoice[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(TENANT_ADMIN)
  tenantId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Product {
  id          String    @id @default(uuid())
  tenantId    String
  amount      Float // valor recebido em MZN que dispara este pacote
  description String
  megabytes   Int?
  operator    Operator?
  autoDetect  Boolean   @default(true)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([tenantId, amount, operator])
}

model Transaction {
  id          String   @id @default(uuid())
  tenantId    String
  productId   String?
  phoneNumber String
  amount      Float
  operator    Operator
  status      TxStatus @default(pending)
  reference   String?
  rawMessage  String?
  createdAt   DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([tenantId, createdAt])
}

model ApiKey {
  id         String    @id @default(uuid())
  tenantId   String
  name       String    @default("MacroDroid")
  key        String    @unique
  lastUsedAt DateTime?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Subscription {
  id               String    @id @default(uuid())
  tenantId         String    @unique
  planId           String
  status           SubStatus @default(trial)
  currentPeriodEnd DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])
}

model Invoice {
  id        String   @id @default(uuid())
  tenantId  String
  amount    Float
  status    String   @default("pending") // paid | failed | pending
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
