[Unit]
Description=Ponte WhatsApp -> HostAgente (comprovantes M-Pesa/eMola)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# AJUSTA: o teu utilizador e o caminho real da pasta
User=usuario
WorkingDirectory=/home/usuario/whatsapp-bridge
ExecStart=/usr/bin/node index.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
